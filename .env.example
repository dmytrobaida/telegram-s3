# HTTP
PORT=3000

# Telegram storage backend. Create a bot with @BotFather, then add it to a private channel/group
# or message it once, and set the numeric chat/channel id here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# S3 credentials Dokploy should use.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=us-east-1

# Metadata persistence. Mount /data as a persistent volume in Docker.
METADATA_FILE=/data/metadata.json

# Telegram Bot API accepts uploads up to about 50 MB. Keep this under that limit.
TELEGRAM_PART_SIZE=47185920
MAX_OBJECT_SIZE=500mb
