# HTTP
PORT=3000

# Telegram storage backend. Create a bot with @BotFather, then add it to a private channel/group
# or message it once, and set the numeric chat/channel id here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# S3 credentials Dokploy should use.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=us-east-1

# Metadata persistence for local Node/Nest runs.
# Docker and Docker Compose override this to /data/metadata.json.
METADATA_FILE=./data/metadata.json

# Telegram Bot API can upload larger files than it can download via getFile.
# Keep parts below 20 MiB so uploaded objects can be restored/downloaded.
TELEGRAM_PART_SIZE=19922944
MAX_OBJECT_SIZE=500mb
